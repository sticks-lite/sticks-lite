{
  "name": "sticks-lite",
  "version": "1.0.1",
  "description": "The Sticks Lite compiler/interpreter and CLI.",
  "keywords": [
    "language",
    "education",
    "educational",
    "interpreter",
    "compiler",
    "classroom",
    "teaching"
  ],
  "homepage": "https://github.com/sticks-lite/sticks-lite#readme",
  "bugs": {
    "url": "https://github.com/sticks-lite/sticks-lite/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sticks-lite/sticks-lite.git"
  },
  "license": "MIT",
  "author": "brisqdev",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sticks": "dist/cli/main.js"
  },
  "directories": {
    "example": "examples",
    "test": "tests"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli/main.ts",
    "test": "vitest run",
    "check": "npm test && npm run build",
    "prepublishOnly": "npm run check"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}

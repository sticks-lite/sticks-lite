{
  "name": "sticks-lite",
  "version": "1.0.3",
  "description": "The Sticks Lite compiler/interpreter and CLI.",
  "keywords": [
    "language",
    "education",
    "educational",
    "interpreter",
    "compiler",
    "classroom",
    "teaching"
  ],
  "homepage": "https://github.com/sticks-lite/sticks-lite#readme",
  "bugs": {
    "url": "https://github.com/sticks-lite/sticks-lite/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sticks-lite/sticks-lite.git"
  },
  "license": "MIT",
  "author": "brisqdev",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sticks": "dist/cli/main.js"
  },
  "directories": {
    "example": "examples",
    "test": "tests"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli/main.ts",
    "test": "vitest run",
    "check": "npm test && npm run build",
    "prepublishOnly": "npm run check"
  },
  "dependencies": {
    "assertion-error": "^2.0.1",
    "chai": "^6.2.2",
    "convert-source-map": "^2.0.0",
    "detect-libc": "^2.1.2",
    "es-module-lexer": "^2.1.0",
    "esbuild": "^0.28.1",
    "estree-walker": "^3.0.3",
    "expect-type": "^1.3.0",
    "fdir": "^6.5.0",
    "fsevents": "^2.3.3",
    "lightningcss": "^1.32.0",
    "lightningcss-darwin-arm64": "^1.32.0",
    "magic-string": "^0.30.21",
    "nanoid": "^3.3.12",
    "obug": "^2.1.2",
    "pathe": "^2.0.3",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.15",
    "rolldown": "^1.0.3",
    "siginfo": "^2.0.0",
    "source-map-js": "^1.2.1",
    "stackback": "^0.0.2",
    "std-env": "^4.1.0",
    "tinybench": "^2.9.0",
    "tinyexec": "^1.2.4",
    "tinyglobby": "^0.2.17",
    "tinyrainbow": "^3.1.0",
    "undici-types": "^7.24.6",
    "vite": "^8.0.16",
    "why-is-node-running": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}

{
  "name": "sticks-lite",
  "version": "1.0.25",
  "description": "The Sticks Lite interpreter and CLI.",
  "keywords": [
    "language",
    "education",
    "educational",
    "interpreter",
    "classroom",
    "teaching"
  ],
  "homepage": "https://github.com/sticks-lite/sticks-lite#readme",
  "bugs": {
    "url": "https://github.com/sticks-lite/sticks-lite/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sticks-lite/sticks-lite.git"
  },
  "license": "MIT",
  "author": "brisqdev",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sticks": "dist/cli/main.js"
  },
  "directories": {
    "test": "tests"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "npm run build --silent && node dist/cli/main.js",
    "test": "npm run test:all",
    "test:all": "vitest run",
    "test:syntax": "vitest run tests/syntax-features.test.ts",
    "test:builtins": "vitest run tests/builtins-all.test.ts",
    "test:cli": "vitest run tests/cli.test.ts tests/cli-modes.test.ts",
    "test:browser": "vitest run tests/browser-safe-core.test.ts",
    "check": "npm run test:all && npm run build",
    "audit:prod": "npm audit --omit=dev",
    "package:dry-run": "npm pack --dry-run",
    "ci:verify": "npm run check && npm run audit:prod",
    "release:check": "npm run ci:verify && npm run package:dry-run",
    "prepublishOnly": "npm run check"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "vite": "6.4.3"
  }
}
